<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/card_background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ایجاد کلاس جدید"
        android:textColor="@color/title_blue"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="نام کلاس (مثلاً ترم ۶ استاد کمالی)"
        app:boxStrokeColor="#FF6B00"
        app:hintTextColor="#FF6B00">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDialogClassName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/main_text"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:hint="ساعت شروع (مثلاً ۱۷:۰۰)"
        app:boxStrokeColor="#FF6B00"
        app:hintTextColor="#FF6B00">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDialogClassStartTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/main_text"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="ساعت پایان (مثلاً ۱۸:۳۰)"
        app:boxStrokeColor="#FF6B00">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDialogClassEndTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="time"
            android:textColor="@color/main_text" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="روزهای هفته (مثلاً شنبه، دوشنبه)"
        app:boxStrokeColor="#FF6B00">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDialogClassDays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/main_text" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:hint="تعداد جلسات"
        app:boxStrokeColor="#FF6B00">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDialogSessionCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textColor="@color/main_text" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnDialogAdd"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="ثبت و ایجاد کلاس"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF6B00"
        app:cornerRadius="12dp" />
</LinearLayout>
