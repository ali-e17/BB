<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp"
    android:layout_marginVertical="7dp"
    android:layoutDirection="rtl"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtManageClassName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="نام کلاس"
            android:textColor="@color/title_blue"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtManageClassTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="روز و ساعت کلاس"
            android:textColor="@color/main_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtManageClassTeacher"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="استاد: تعیین نشده"
            android:textColor="@color/sub_text"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManageMembers"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="اعضا"
                android:textSize="12sp"
                app:cornerRadius="10dp"
                app:strokeColor="@color/title_blue" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditClass"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="5dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="ویرایش"
                android:textSize="12sp"
                app:cornerRadius="10dp"
                app:strokeColor="@color/brand_orange" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCompleteClass"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="پایان ترم"
                android:textColor="#EF4444"
                android:textSize="11sp"
                app:cornerRadius="10dp"
                app:strokeColor="#EF4444" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
