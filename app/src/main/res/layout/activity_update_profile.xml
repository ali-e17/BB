<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_global_background"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <RelativeLayout
            android:id="@+id/updateProfileToolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/btnUpdateProfileBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/main_text"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="تغییر رمز عبور"
                android:textColor="@color/title_blue"
                android:textSize="18sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutOldPassword"
            style="@style/UnifiedOutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="رمز عبور فعلی"
            android:layoutDirection="rtl"
            app:hintTextColor="#FF6B00"
            android:textColorHint="@color/hint_color"
            app:boxStrokeColor="@color/unified_field_stroke"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="@color/title_blue"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etOldPassword"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:textColor="@color/input_text"
                android:textStyle="bold"
                android:textDirection="ltr"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutNewPassword"
            style="@style/UnifiedOutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="رمز عبور جدید"
            android:layoutDirection="rtl"
            app:hintTextColor="#FF6B00"
            android:textColorHint="@color/hint_color"
            app:boxStrokeColor="@color/unified_field_stroke"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="@color/title_blue"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNewPassword"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:textColor="@color/input_text"
                android:textStyle="bold"
                android:textDirection="ltr"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutConfirmPassword"
            style="@style/UnifiedOutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:hint="تکرار رمز عبور جدید"
            android:layoutDirection="rtl"
            app:hintTextColor="#FF6B00"
            android:textColorHint="@color/hint_color"
            app:boxStrokeColor="@color/unified_field_stroke"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="@color/title_blue"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:textColor="@color/input_text"
                android:textStyle="bold"
                android:textDirection="ltr"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnUpdatePassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="تغییر رمز عبور"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF6B00"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>