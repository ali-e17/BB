<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <androidx.cardview.widget.CardView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_background">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@android:drawable/sym_def_app_icon"
                android:scaleType="centerCrop"
                android:background="@color/card_background"/>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/btnChangeAvatar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="تغییر آواتار"
            android:textColor="@color/title_blue"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"
            android:padding="4dp"/>

        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="کاربر مهمان"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/main_text"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvUserRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="نقش کاربری"
            android:textSize="14sp"
            android:textColor="#FF6B00"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="32dp" />

        <LinearLayout
            android:id="@+id/btnChangeCredentials"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/bg_input_field"
            android:backgroundTint="@color/card_background"
            android:orientation="horizontal"
            android:gravity="center_vertical|right"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تغییر نام کاربری و رمز عبور"
                android:textColor="@color/main_text"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginRight="12dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutStudentOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/btnStudentClasses"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="@color/card_background"
                android:orientation="horizontal"
                android:gravity="center_vertical|right"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="مشاهده کلاس‌های ثبت‌نام شده"
                    android:textColor="@color/main_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnStudentReportCards"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="@color/card_background"
                android:orientation="horizontal"
                android:gravity="center_vertical|right"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="مشاهده کارنامه‌ها و نمرات"
                    android:textColor="@color/main_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutTeacherOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/btnTeacherHistory"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="@color/card_background"
                android:orientation="horizontal"
                android:gravity="center_vertical|right"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="سابقه کل کلاس‌های اخذ شده"
                    android:textColor="@color/main_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/bg_input_field"
            android:backgroundTint="@color/logout_bg_color"
            android:orientation="horizontal"
            android:gravity="center_vertical|right"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_lock_power_off"
                app:tint="@color/logout_text_color"
                android:layout_marginRight="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="خروج از حساب کاربری"
                android:textColor="@color/logout_text_color"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>