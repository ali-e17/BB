<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8FAFC"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <androidx.cardview.widget.CardView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="50dp"
        app:cardElevation="2dp">

        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@android:drawable/sym_def_app_icon"
            android:scaleType="centerCrop"
            android:background="#E2E8F0"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvUserName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="کاربر مهمان"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1E293B"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tvUserRole"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="نقش کاربری"
        android:textSize="14sp"
        android:textColor="#FF6B00"
        android:textStyle="bold"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="32dp" />

    <LinearLayout
        android:id="@+id/btnChangeCredentials"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/bg_input_field"
        android:orientation="horizontal"
        android:gravity="center_vertical|right"
        android:paddingHorizontal="16dp"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تغییر نام کاربری و رمز عبور"
            android:textColor="#334155"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginRight="12dp"/>
    </LinearLayout>


    <LinearLayout
        android:id="@+id/layoutStudentOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"> <LinearLayout
        android:id="@+id/btnStudentClasses"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/bg_input_field"
        android:orientation="horizontal"
        android:gravity="center_vertical|right"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="12dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="مشاهده کلاس‌های ثبت‌نام شده"
            android:textColor="#334155"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

        <LinearLayout
            android:id="@+id/btnStudentReportCards"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/bg_input_field"
            android:orientation="horizontal"
            android:gravity="center_vertical|right"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مشاهده کارنامه‌ها و نمرات"
                android:textColor="#334155"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>


    <LinearLayout
        android:id="@+id/layoutTeacherOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"> <LinearLayout
        android:id="@+id/btnTeacherHistory"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/bg_input_field"
        android:orientation="horizontal"
        android:gravity="center_vertical|right"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="12dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="سابقه کل کلاس‌های اخذ شده"
            android:textColor="#334155"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
    </LinearLayout>

</LinearLayout>
</ScrollView>