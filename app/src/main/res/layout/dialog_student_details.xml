<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/card_background"
    android:layoutDirection="rtl"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="12dp"
    android:paddingEnd="22dp"
    android:paddingBottom="22dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:alpha="0.28"
        android:background="@color/sub_text" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layoutDirection="ltr"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/dialogAvatar"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/avatar_student_1" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:layoutDirection="rtl"
            android:gravity="right"
            android:orientation="vertical">

            <TextView
                android:id="@+id/dialogName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="right"
                android:textColor="@color/title_blue"
                android:textDirection="rtl"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialogCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="right"
                android:textColor="@color/sub_text"
                android:textDirection="rtl"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeColor="#353559B8"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layoutDirection="rtl"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout style="@style/StudentCompactDetailRow">
                <TextView style="@style/StudentCompactDetailLabel" android:text="کلاس" />
                <TextView
                    android:id="@+id/dialogLevel"
                    style="@style/StudentCompactDetailValue"
                    android:textStyle="bold" />
            </LinearLayout>

            <View style="@style/StudentCompactDetailDivider" />

            <LinearLayout style="@style/StudentCompactDetailRow">
                <TextView style="@style/StudentCompactDetailLabel" android:text="شماره تماس" />
                <TextView
                    android:id="@+id/dialogPhone"
                    style="@style/StudentCompactDetailValue"
                    android:textDirection="ltr" />
            </LinearLayout>

            <View style="@style/StudentCompactDetailDivider" />

            <LinearLayout style="@style/StudentCompactDetailRow">
                <TextView style="@style/StudentCompactDetailLabel" android:text="کد ملی" />
                <TextView
                    android:id="@+id/dialogNationalId"
                    style="@style/StudentCompactDetailValue"
                    android:textDirection="ltr" />
            </LinearLayout>

            <View style="@style/StudentCompactDetailDivider" />

            <LinearLayout style="@style/StudentCompactDetailRow">
                <TextView style="@style/StudentCompactDetailLabel" android:text="تاریخ ثبت‌نام" />
                <TextView
                    android:id="@+id/dialogRegDate"
                    style="@style/StudentCompactDetailValue"
                    android:textDirection="ltr" />
            </LinearLayout>

            <View style="@style/StudentCompactDetailDivider" />

            <LinearLayout style="@style/StudentCompactDetailRow">
                <TextView style="@style/StudentCompactDetailLabel" android:text="وضعیت حساب" />
                <TextView
                    android:id="@+id/dialogStatus"
                    style="@style/StudentCompactDetailValue"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layoutDirection="rtl"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogEdit"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:backgroundTint="@color/brand_orange"
            android:text="ویرایش اطلاعات"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:cornerRadius="12dp" />

        <View
            android:layout_width="10dp"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogArchive"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:textColor="@color/title_blue"
            app:cornerRadius="12dp"
            app:strokeColor="@color/title_blue" />
    </LinearLayout>
</LinearLayout>
