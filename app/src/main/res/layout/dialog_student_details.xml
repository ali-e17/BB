<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/card_background"
    android:orientation="vertical"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="@color/sub_text"
        android:alpha="0.3" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/dialogAvatar"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/avatar_student_1" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/dialogName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/title_blue"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialogCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/sub_text"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="20dp"
        android:background="@color/sub_text"
        android:alpha="0.2" />

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TableRow android:layout_marginBottom="12dp">
            <TextView android:text="سطح آموزشی:" android:textColor="@color/sub_text" android:textSize="14sp" android:paddingEnd="16dp"/>
            <TextView android:id="@+id/dialogLevel" android:textColor="@color/main_text" android:textSize="14sp" android:textStyle="bold"/>
        </TableRow>

        <TableRow android:layout_marginBottom="12dp">
            <TextView android:text="شماره تماس:" android:textColor="@color/sub_text" android:textSize="14sp" android:paddingEnd="16dp"/>
            <TextView android:id="@+id/dialogPhone" android:textColor="@color/main_text" android:textSize="14sp"/>
        </TableRow>

        <TableRow android:layout_marginBottom="12dp">
            <TextView android:text="تاریخ ثبت‌نام:" android:textColor="@color/sub_text" android:textSize="14sp" android:paddingEnd="16dp"/>
            <TextView android:id="@+id/dialogRegDate" android:textColor="@color/main_text" android:textSize="14sp"/>
        </TableRow>

        <TableRow>
            <TextView android:text="وضعیت حساب:" android:textColor="@color/sub_text" android:textSize="14sp" android:paddingEnd="16dp"/>
            <TextView android:id="@+id/dialogStatus" android:textSize="14sp" android:textStyle="bold"/>
        </TableRow>
    </TableLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogArchive"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:textColor="@color/title_blue"
            app:strokeColor="@color/title_blue"
            app:cornerRadius="12dp"/>

        <View android:layout_width="12dp" android:layout_height="1dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogEdit"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="ویرایش اطلاعات"
            android:backgroundTint="@color/brand_orange"
            android:textColor="@color/white"
            app:cornerRadius="12dp"/>
    </LinearLayout>
</LinearLayout>