<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/app_global_background">

    <RelativeLayout
        android:id="@+id/setupToolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/btnSetupBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/main_text" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="تنظیمات بارم‌بندی کلاس"
            android:textColor="@color/title_blue"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/dropdownClassLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        android:textColorHint="@color/sub_text"
        app:hintTextColor="@color/title_blue"
        app:boxStrokeColor="@color/title_blue"
        app:boxBackgroundColor="@android:color/transparent"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:layout_constraintTop_toBottomOf="@id/setupToolbar">

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/dropdownClassTarget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/main_text"
            android:hint="انتخاب کلاس برای ثبت نمره"
            android:inputType="none"
            android:background="@null"
            android:popupBackground="@color/card_background" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTotalStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="16dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/dropdownClassLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center">

            <TextView
                android:id="@+id/txtTotalSumLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مجموع بارم‌بندی فعلی"
                android:textColor="@color/sub_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtTotalSumValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="100 / 100"
                android:textColor="#10B981"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtValidationHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="بارم‌بندی معتبر است. آماده ثبت نمرات."
                android:textColor="#10B981"
                android:textSize="12sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/btnSaveLayout"
        app:layout_constraintTop_toBottomOf="@id/cardTotalStatus">

        <LinearLayout
            android:id="@+id/containerFields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp" />
    </ScrollView>

    <Button
        android:id="@+id/btnSaveLayout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        android:text="تایید و ورود به ثبت نمرات"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF6B00"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>