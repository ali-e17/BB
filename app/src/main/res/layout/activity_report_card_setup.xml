<?xml version='1.0' encoding='utf-8'?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:fitsSystemWindows="true" android:background="@drawable/app_global_background">
  <com.google.android.material.card.MaterialCardView android:id="@+id/setupToolbar" android:layout_width="match_parent" android:layout_height="64dp" app:cardBackgroundColor="@color/card_background" app:cardCornerRadius="0dp" app:cardElevation="2dp" app:layout_constraintTop_toTopOf="parent">
    <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
      <ImageView android:id="@+id/btnSetupBack" android:layout_width="48dp" android:layout_height="48dp" android:layout_alignParentLeft="true" android:layout_centerVertical="true" android:layout_marginLeft="8dp" android:padding="12dp" android:src="@android:drawable/ic_menu_revert" android:contentDescription="بازگشت" app:tint="@color/main_text"/>
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" android:text="ساخت کارنامه" android:textColor="@color/title_blue" android:textSize="18sp" android:textStyle="bold"/>
    </RelativeLayout>
  </com.google.android.material.card.MaterialCardView>
  <LinearLayout android:id="@+id/stepHeader" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="20dp" android:paddingTop="14dp" android:paddingEnd="20dp" android:paddingBottom="10dp" app:layout_constraintTop_toBottomOf="@id/setupToolbar">
    <TextView android:id="@+id/txtStepTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="مرحله ۱ از ۲ · انتخاب کلاس" android:textColor="@color/main_text" android:textSize="14sp" android:textStyle="bold"/>
    <com.google.android.material.progressindicator.LinearProgressIndicator android:id="@+id/stepProgress" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="8dp" android:max="100" android:progress="50" app:indicatorColor="@color/title_blue" app:trackColor="#1A2B4E78" app:trackCornerRadius="3dp"/>
  </LinearLayout>
  <FrameLayout android:id="@+id/setupContent" android:layout_width="match_parent" android:layout_height="0dp" app:layout_constraintTop_toBottomOf="@id/stepHeader" app:layout_constraintBottom_toBottomOf="parent">
    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/stepClassPanel" android:layout_width="match_parent" android:layout_height="match_parent" android:visibility="visible">
      <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="0dp" android:fillViewport="true" android:clipToPadding="false" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@id/btnChooseClassContinue">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
          <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardBackgroundColor="@color/card_background" app:cardCornerRadius="20dp" app:cardElevation="2dp" app:strokeColor="#1A2B4E78" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
              <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="کلاس موردنظر را انتخاب کنید" android:textColor="@color/main_text" android:textSize="18sp" android:textStyle="bold"/>
              <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="معیارها و نمرات فقط برای همین کلاس ثبت می‌شوند." android:textColor="@color/sub_text" android:textSize="13sp"/>
              <com.google.android.material.textfield.TextInputLayout android:id="@+id/dropdownClassLayout" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:hint="انتخاب کلاس" app:boxCornerRadiusTopStart="14dp" app:boxCornerRadiusTopEnd="14dp" app:boxCornerRadiusBottomStart="14dp" app:boxCornerRadiusBottomEnd="14dp" app:boxStrokeColor="@color/title_blue" app:hintTextColor="@color/title_blue">
                <com.google.android.material.textfield.MaterialAutoCompleteTextView android:id="@+id/dropdownClassTarget" android:layout_width="match_parent" android:layout_height="56dp" android:background="@null" android:inputType="none" android:paddingHorizontal="12dp" android:textColor="@color/main_text" android:textSize="15sp"/>
              </com.google.android.material.textfield.TextInputLayout>
              <TextView android:id="@+id/txtClassSelectionHint" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="بعد از انتخاب کلاس، برنامه آن اینجا نمایش داده می‌شود." android:textColor="@color/sub_text" android:textSize="12sp"/>
            </LinearLayout>
          </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
      </androidx.core.widget.NestedScrollView>
      <com.google.android.material.button.MaterialButton android:id="@+id/btnChooseClassContinue" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginHorizontal="20dp" android:layout_marginBottom="20dp" android:text="ادامه و تنظیم معیارها" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" android:enabled="false" android:alpha="0.5" android:backgroundTint="#FF6B00" app:cornerRadius="14dp" app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/stepCriteriaPanel" android:layout_width="match_parent" android:layout_height="match_parent" android:visibility="gone">
      <com.google.android.material.card.MaterialCardView android:id="@+id/selectedClassCard" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="16dp" android:layout_marginTop="4dp" app:cardBackgroundColor="@color/card_background" app:cardCornerRadius="16dp" app:cardElevation="1dp" app:strokeColor="#1A2B4E78" app:strokeWidth="1dp" app:layout_constraintTop_toTopOf="parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_vertical" android:padding="14dp">
          <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:id="@+id/txtSelectedClassName" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="نام کلاس" android:textColor="@color/main_text" android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:id="@+id/txtSelectedClassTime" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="برنامه کلاس" android:textColor="@color/sub_text" android:textSize="12sp"/>
          </LinearLayout>
        </LinearLayout>
      </com.google.android.material.card.MaterialCardView>
      <!-- Summary of selected criteria stays visible at the top. -->
      <com.google.android.material.card.MaterialCardView android:id="@+id/topSummaryCard" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="16dp" app:cardBackgroundColor="@color/card_background" app:cardCornerRadius="16dp" app:cardElevation="1dp" app:strokeColor="#1A2B4E78" app:strokeWidth="1dp" android:layout_marginTop="12dp" app:layout_constraintTop_toBottomOf="@id/selectedClassCard">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp">
          <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
              <TextView android:id="@+id/txtTotalSumValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 / 100" android:textColor="#EF4444" android:textSize="24sp" android:textStyle="bold"/>
              <TextView android:id="@+id/txtSelectedCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="1dp" android:text="0 معیار انتخاب شده" android:textColor="@color/sub_text" android:textSize="12sp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="مجموع بارم" android:textColor="@color/sub_text" android:textSize="13sp" android:textStyle="bold"/>
          </LinearLayout>
          <TextView android:id="@+id/txtValidationHint" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="حداقل یک معیار را فعال کنید." android:textColor="#EF4444" android:textSize="12sp"/>
        </LinearLayout>
      </com.google.android.material.card.MaterialCardView>
      <LinearLayout android:id="@+id/criteriaHeader" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="20dp" android:layout_marginTop="14dp" android:gravity="center_vertical" android:orientation="horizontal" app:layout_constraintTop_toBottomOf="@id/topSummaryCard">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="معیارهای کارنامه" android:textColor="@color/main_text" android:textSize="16sp" android:textStyle="bold"/>
      </LinearLayout>
      <androidx.core.widget.NestedScrollView android:id="@+id/criteriaScroll" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="4dp" android:clipToPadding="false" android:fillViewport="true" app:layout_constraintTop_toBottomOf="@id/criteriaHeader" app:layout_constraintBottom_toTopOf="@id/bottomActionCard" android:layout_marginBottom="8dp">
        <LinearLayout android:id="@+id/containerFields" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="16dp" android:paddingBottom="12dp"/>
      </androidx.core.widget.NestedScrollView>
      <!-- Continue is the only fixed bottom action. -->
      <com.google.android.material.card.MaterialCardView android:id="@+id/bottomActionCard" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="12dp" android:layout_marginBottom="12dp" app:cardBackgroundColor="@color/card_background" app:cardCornerRadius="18dp" app:cardElevation="8dp" app:strokeColor="#1A2B4E78" app:strokeWidth="1dp" app:layout_constraintBottom_toBottomOf="parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
          <com.google.android.material.button.MaterialButton android:id="@+id/btnSaveLayout" android:layout_width="match_parent" android:layout_height="56dp" android:text="تأیید و ورود به ثبت نمرات" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold" android:enabled="false" android:alpha="0.5" android:backgroundTint="#FF6B00" app:cornerRadius="14dp"/>
        </LinearLayout>
      </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
  </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
