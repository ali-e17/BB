<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp" android:layout_marginVertical="6dp" app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="14dp" app:cardElevation="2dp" app:strokeColor="#353559B8" app:strokeWidth="1dp">
    <LinearLayout android:id="@+id/itemTeacherRoot" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center_vertical" android:orientation="horizontal" android:padding="14dp">
        <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/bg_circle_icon"
            android:backgroundTint="@color/bg_blue_light" android:backgroundTintMode="src_atop">
            <ImageView android:id="@+id/ivTeacherAvatar" android:layout_width="44dp" android:layout_height="44dp"
                android:layout_gravity="center" android:scaleType="centerCrop" android:src="@drawable/avatar_teacher_1" />
        </FrameLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="14dp"
            android:layout_weight="1" android:gravity="right" android:orientation="vertical">
            <TextView android:id="@+id/tvTeacherName" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="right" android:textColor="@color/main_text" android:textDirection="rtl" android:textSize="15sp" android:textStyle="bold" />
            <TextView android:id="@+id/tvTeacherUsername" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="4dp" android:gravity="right" android:textColor="@color/sub_text" android:textDirection="rtl" android:textSize="12sp" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="right"
                android:layout_marginTop="7dp" android:orientation="horizontal">
                <TextView android:id="@+id/tvTeacherClassCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:background="@drawable/bg_unified_info_badge" android:text="بدون کلاس" android:textColor="@color/title_blue" android:textSize="10sp" android:textStyle="bold" />
                <TextView android:id="@+id/txtArchivedBadge" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="7dp" android:background="@drawable/bg_unified_status_inactive" android:text="بایگانی‌شده"
                    android:textColor="@color/sub_text" android:textSize="10sp" android:textStyle="bold" android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
        <com.google.android.material.button.MaterialButton android:id="@+id/btnViewTeacherDetails"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="42dp"
            android:minWidth="76dp" android:text="جزئیات" android:textColor="@color/title_blue" android:textSize="12sp"
            app:cornerRadius="11dp" app:icon="@android:drawable/ic_menu_info_details" app:iconTint="@color/title_blue"
            app:strokeColor="@color/title_blue" app:strokeWidth="1dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
