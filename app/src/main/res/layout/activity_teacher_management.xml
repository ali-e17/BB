<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@drawable/app_global_background" android:fitsSystemWindows="true" android:layoutDirection="rtl">

    <com.google.android.material.card.MaterialCardView android:id="@+id/topBarTeachers" android:layout_width="match_parent" android:layout_height="64dp"
        android:layout_marginHorizontal="20dp" android:layout_marginTop="16dp" app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="20dp" app:cardElevation="12dp" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:strokeWidth="0dp">
        <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
            <ImageView android:id="@+id/btnTeacherMgmtBack" android:layout_width="48dp" android:layout_height="48dp"
                android:layout_alignParentLeft="true" android:layout_centerVertical="true" android:background="?android:attr/selectableItemBackgroundBorderless"
                android:padding="12dp" android:src="@android:drawable/ic_menu_revert" app:tint="@color/main_text" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true"
                android:text="مدیریت اساتید" android:textColor="@color/title_blue" android:textSize="18sp" android:textStyle="bold" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout android:id="@+id/teacherFilters" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="14dp" android:orientation="vertical" android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/topBarTeachers">
        <com.google.android.material.textfield.TextInputLayout style="@style/UnifiedOutlinedBox"
            android:layout_width="match_parent" android:layout_height="wrap_content" app:startIconDrawable="@android:drawable/ic_menu_search" app:startIconTint="@color/sub_text">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etSearchTeacher" android:layout_width="match_parent" android:layout_height="56dp"
                android:gravity="right|center_vertical" android:hint="جست‌وجوی نام یا شماره تماس" android:inputType="text" android:textColor="@color/main_text" android:textDirection="rtl" />
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout style="@style/UnifiedOutlinedDropdown"
            android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" app:hintEnabled="false">
            <com.google.android.material.textfield.MaterialAutoCompleteTextView android:id="@+id/spinnerTeacherStatusFilter"
                android:layout_width="match_parent" android:layout_height="56dp" android:background="@null" android:gravity="right|center_vertical"
                android:inputType="none" android:paddingHorizontal="16dp" android:textColor="@color/main_text" android:textDirection="rtl" />
        </com.google.android.material.textfield.TextInputLayout>
        <TextView android:id="@+id/txtTeacherCount" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="10dp" android:gravity="right" android:text="۰ استاد" android:textColor="@color/sub_text" android:textDirection="rtl" android:textSize="12sp" android:textStyle="bold" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvTeachers" android:layout_width="match_parent" android:layout_height="0dp"
        android:clipToPadding="false" android:paddingTop="6dp" android:paddingBottom="90dp"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintTop_toBottomOf="@id/teacherFilters" />

    <LinearLayout android:id="@+id/teacherEmptyState" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:gravity="center" android:orientation="vertical" android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/rvTeachers" app:layout_constraintEnd_toEndOf="@id/rvTeachers"
        app:layout_constraintStart_toStartOf="@id/rvTeachers" app:layout_constraintTop_toTopOf="@id/rvTeachers">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="استادی پیدا نشد"
            android:textColor="@color/sub_text" android:textSize="14sp" android:textStyle="bold" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton android:id="@+id/fabAddTeacher"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="24dp" android:layout_marginBottom="24dp"
        android:src="@android:drawable/ic_input_add" app:backgroundTint="@color/brand_orange" app:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:tint="@color/white" />
</androidx.constraintlayout.widget.ConstraintLayout>
