<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/card_background"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="@color/sub_text"
        android:alpha="0.3" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_circle_icon"
            android:backgroundTint="@color/bg_blue_light"
            android:backgroundTintMode="src_atop">

            <TextView
                android:id="@+id/dialogTeacherAvatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/title_blue"
                android:textSize="24sp"
                android:textStyle="bold"
                android:text="ا" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="right">

            <TextView
                android:id="@+id/dialogTeacherName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/title_blue"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialogTeacherUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/sub_text"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="20dp"
        android:background="@color/sub_text"
        android:alpha="0.2" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="کلاس فعلی"
                android:textColor="@color/sub_text"
                android:textSize="14sp"
                android:gravity="right" />

            <TextView
                android:id="@+id/dialogTeacherClass"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/main_text"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="right" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="وضعیت حساب"
                android:textColor="@color/sub_text"
                android:textSize="14sp"
                android:gravity="right" />

            <TextView
                android:id="@+id/dialogTeacherStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="right" />
        </LinearLayout>

        <TextView
            android:id="@+id/dialogTeacherArchiveHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="برای بایگانی کردن، ابتدا کلاس این استاد را از او بگیرید."
            android:textColor="#EF4444"
            android:textSize="12sp"
            android:gravity="right"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogTeacherArchive"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:textColor="@color/title_blue"
            app:strokeColor="@color/title_blue"
            app:cornerRadius="12dp"/>

        <View android:layout_width="12dp" android:layout_height="1dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogTeacherEdit"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="ویرایش اطلاعات"
            android:backgroundTint="@color/brand_orange"
            android:textColor="@color/white"
            app:cornerRadius="12dp"/>
    </LinearLayout>
</LinearLayout>
