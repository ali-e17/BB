<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layoutDirection="rtl">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/textInputLayoutScore"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="104dp"
        android:layout_height="wrap_content"
        app:errorEnabled="true"
        app:boxStrokeColor="@color/title_blue"
        app:hintTextColor="@color/title_blue"
        app:boxCornerRadiusTopStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusBottomEnd="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etScoreInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="3"
            android:text="0"
            android:textColor="@color/input_text"
            android:textSize="14sp"
            android:padding="12dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/txtCriteriaName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:gravity="right"
        android:text="معیار نمره"
        android:textColor="@color/main_text"
        android:textSize="14sp"
        app:layout_constraintEnd_toStartOf="@id/textInputLayoutScore"
        app:layout_constraintStart_toEndOf="@id/btnAbsent"
        app:layout_constraintTop_toTopOf="@id/textInputLayoutScore"
        app:layout_constraintBottom_toBottomOf="@id/textInputLayoutScore" />

    <Button
        android:id="@+id/btnAbsent"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="غایب (۰)"
        android:textColor="#F43F5E"
        android:textSize="12sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/textInputLayoutScore"
        app:layout_constraintBottom_toBottomOf="@id/textInputLayoutScore" />

</androidx.constraintlayout.widget.ConstraintLayout>
