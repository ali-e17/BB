<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0B132B" />
        </shape>
    </item>

    <item android:gravity="top" android:height="300dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1E295D"
                android:endColor="#000B132B"
                android:angle="270" />
        </shape>
    </item>
</layer-list>