<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ClassFormLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">14dp</item>
        <item name="android:layout_marginBottom">7dp</item>
        <item name="android:gravity">right|center_vertical</item>
        <item name="android:textColor">@color/main_text</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ClassFormSectionTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">22dp</item>
        <item name="android:layout_marginBottom">9dp</item>
        <item name="android:gravity">right|center_vertical</item>
        <item name="android:textColor">@color/title_blue</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ClassFormOutlinedBox" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/card_background</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/class_field_stroke</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeWidthFocused">3dp</item>
        <item name="hintEnabled">false</item>
    </style>

    <style name="ClassFormOutlinedBox.ExposedDropdown" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">@color/card_background</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/class_field_stroke</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeWidthFocused">3dp</item>
        <item name="hintEnabled">false</item>
    </style>

    <style name="ClassDayChip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:textColor">@color/class_chip_text</item>
        <item name="android:textSize">13sp</item>
        <item name="chipBackgroundColor">@color/class_chip_background</item>
        <item name="chipStrokeColor">@color/class_chip_stroke</item>
        <item name="chipStrokeWidth">1.5dp</item>
        <item name="checkedIconVisible">true</item>
        <item name="checkedIconTint">@color/white</item>
        <item name="chipCornerRadius">12dp</item>
    </style>
</resources>
